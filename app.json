{
  "expo": {
    "name": "Lumora",
    "slug": "dark-player",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/black.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/lumora-name-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Lumora needs access to your photo library to display and manage your images.",
        "NSPhotoLibraryAddUsageDescription": "Lumora needs access to save images to your photo library.",
        "NSCameraUsageDescription": "Lumora needs camera access to take photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.darkmanager.app"
    },
    "android": {
      "package": "com.darkmanager.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/black.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Lumora to access your photos.",
          "savePhotosPermission": "Allow Lumora to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "39e64c2f-573a-4d24-83ac-8e332d418794"
      }
    },
    "owner": "cadmuslabss-organization"
  }
}
