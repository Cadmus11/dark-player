{
  "expo": {
    "name": "Lumora",
    "slug": "dark-player",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Lumora needs access to your photo library to display and manage your images.",
        "NSPhotoLibraryAddUsageDescription": "Lumora needs access to save images to your photo library.",
        "NSCameraUsageDescription": "Lumora needs camera access to take photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"]
      },
      "bundleIdentifier": "com.darkmanager.app"
    },
    "android": {
      "package": "com.darkmanager.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_VISUAL_USER_SELECTED",
        "ACCESS_MEDIA_LOCATION",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ],
      "foregroundService": {
        "appsUsing": ["mediaPlayback"]
      }
    },
    "web": {
      "favicon": "./assets/adaptive-icon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Lumora to access your photos.",
          "savePhotosPermission": "Allow Lumora to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Lumora to access your microphone.",
          "enablePip": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "39e64c2f-573a-4d24-83ac-8e332d418794"
      }
    },
    "owner": "cadmuslabss-organization"
  }
}
